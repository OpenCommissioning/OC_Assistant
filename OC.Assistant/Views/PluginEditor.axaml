<Grid xmlns="https://github.com/avaloniaui"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:OC.Assistant.ViewModels"
      x:Class="OC.Assistant.Views.PluginEditor"
      x:DataType="vm:PluginEditorViewModel"
      VerticalAlignment="Stretch"
      IsVisible="{Binding IsVisible}"
      Margin="0 6 0 0">
    <Grid.DataTemplates>
        <DataTemplate DataType="vm:PluginParameterViewModel">
            <Grid ToolTip.Tip="{Binding ToolTip}" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Left"
                       VerticalContentAlignment="Center"
                       HorizontalContentAlignment="Left"
                       Content="{Binding Name}"/>
                <CheckBox Grid.Column="1"
                          IsVisible="{Binding BoolVisibility}"
                          IsChecked="{Binding BoolValue}"/>
                <TextBox Grid.Column="1"
                         IsVisible="{Binding ClearTextVisibility}"
                         Text="{Binding ClearTextValue}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"/>
                <TextBox Grid.Column="1"
                         IsVisible="{Binding PasswordVisibility}"
                         PasswordChar="•"
                         Text="{Binding PasswordValue}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"/>
                <Button Grid.Column="2"
                        IsVisible="{Binding SelectFileVisibility}"
                        Command="{Binding SelectFileCommand}"
                        Width="30"
                        Classes="Secondary"
                        Padding="0"
                        Margin="0"
                        VerticalAlignment="Stretch"
                        Content="..."/>
            </Grid>
        </DataTemplate>
    </Grid.DataTemplates>
    <Grid RowDefinitions="*,Auto">
        <ScrollViewer
            Grid.Row="0">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0">
                    <TextBox ToolTip.Tip="Name of the Plugin instance"
                             Margin="0,0,0,5"
                             Text="{Binding PluginName}"/>
                    <ComboBox ToolTip.Tip="Plugin Type"
                              Margin="0,0,0,5"
                              HorizontalAlignment="Stretch"
                              IsEnabled="{Binding TypeSelectorIsEnabled}"
                              ItemsSource="{Binding AvailableTypes}"
                              SelectedItem="{Binding SelectedType, Mode=TwoWay}"/>
                    <ComboBox ToolTip.Tip="Communication Channel Type"
                              Margin="0,0,0,10"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding AvailableChannels}"
                              SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"/>
                </StackPanel>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Parameters}" Margin="4,0,0,0"/>
            </Grid>
        </ScrollViewer>
        <Grid
            Grid.Row="1"
            Height="54"
            IsVisible="{Binding ApplyDiscardVisibility}"
            ColumnDefinitions="*,*">
            <Button Grid.Column="0"
                    Command="{Binding ApplyCommand}"
                    HorizontalAlignment="Stretch"
                    Classes="Primary"
                    Margin="0,0,5,0"
                    Content="Apply"/>
            <Button Grid.Column="1"
                    Command="{Binding DiscardCommand}"
                    HorizontalAlignment="Stretch"
                    Classes="Secondary"
                    Margin="5,0,0,0"
                    Content="Discard"/>
        </Grid>
    </Grid>
</Grid>

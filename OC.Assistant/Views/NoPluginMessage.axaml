<StackPanel xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="clr-namespace:OC.Assistant.ViewModels"
            x:Class="OC.Assistant.Views.NoPluginMessage"
            x:DataType="vm:PluginListViewModel"
            Margin="0,12,0,0">
    <Label>Create a Plugins folder and place any plugin there.</Label>
    <StackPanel Orientation="Horizontal">
        <Label>Learn more on the</Label>
        <Button Classes="Link"
                Command="{Binding OpenGitHubLinkCommand}"
                Content="Assistant github page"/>
    </StackPanel>
</StackPanel>

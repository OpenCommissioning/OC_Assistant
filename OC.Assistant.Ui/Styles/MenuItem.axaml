<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="Menu">
        <Setter Property="Height" Value="25"/>
    </Style>
    
    <Style Selector="MenuItem">
        <Setter Property="Padding" Value="10 4"/>
        <Setter Property="Margin" Value="3 0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    </Style>
    
    <!-- Keep space reserved when unchecked -->
    <Style Selector="MenuItem:toggle /template/ ContentControl#PART_ToggleIconPresenter">
        <Setter Property="IsVisible" Value="True"/>
        <Setter Property="Opacity" Value="0"/>
    </Style>
    
    <!-- Show checkmark only for checked toggle items -->
    <Style Selector="MenuItem:checked:toggle /template/ ContentControl#PART_ToggleIconPresenter">
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
</Styles>
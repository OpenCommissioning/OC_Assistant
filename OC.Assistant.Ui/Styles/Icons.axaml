<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>

        <ControlTemplate x:Key="WarningIcon" TargetType="ContentControl">
            <ContentControl
                Template="{DynamicResource CombinedIconTemplate}"
                Background="{DynamicResource WarningBrush}"
                Foreground="{DynamicResource SystemChromeBlackHighColor}"
                Content="{DynamicResource IconStatusTriangleOuter}"
                Tag="{DynamicResource IconStatusTriangleExclamation}"
                FontSize="{TemplateBinding FontSize}"/>
        </ControlTemplate>

        <ControlTemplate x:Key="InformationIcon" TargetType="ContentControl">
            <ContentControl
                Template="{DynamicResource CombinedIconTemplate}"
                Background="{DynamicResource SystemAccentColor}"
                Foreground="{DynamicResource SystemChromeWhiteColor}"
                Content="{DynamicResource IconStatusCircleOuter}"
                Tag="{DynamicResource IconStatusCircleInfo}"
                FontSize="{TemplateBinding FontSize}"/>
        </ControlTemplate>

        <ControlTemplate x:Key="ErrorIcon" TargetType="ContentControl">
            <ContentControl
                Template="{DynamicResource CombinedIconTemplate}"
                Background="{DynamicResource DangerBrush}"
                Foreground="{DynamicResource SystemChromeWhiteColor}"
                Content="{DynamicResource IconStatusCircleOuter}"
                Tag="{DynamicResource IconStatusCircleError}"
                FontSize="{TemplateBinding FontSize}"/>
        </ControlTemplate>

        <ControlTemplate x:Key="QuestionIcon" TargetType="ContentControl">
            <ContentControl
                Template="{DynamicResource CombinedIconTemplate}"
                Background="{DynamicResource SystemAccentColor}"
                Foreground="{DynamicResource SystemChromeWhiteColor}"
                Content="{DynamicResource IconStatusCircleOuter}"
                Tag="{DynamicResource IconStatusCircleQuestionMark}"
                FontSize="{TemplateBinding FontSize}"/>
        </ControlTemplate>

        <ControlTemplate x:Key="IconTemplate" TargetType="ContentControl">
            <Viewbox Height="{TemplateBinding FontSize}" Width="{TemplateBinding FontSize}">
                <Path Data="{TemplateBinding Content}" Fill="{TemplateBinding Foreground}"/>
            </Viewbox>
        </ControlTemplate>

        <ControlTemplate x:Key="CombinedIconTemplate" TargetType="ContentControl">
            <Viewbox Height="{TemplateBinding FontSize}" Width="{TemplateBinding FontSize}">
                <Grid>
                    <Path Data="{TemplateBinding Content}" Fill="{TemplateBinding Background}"/>
                    <Path Data="{TemplateBinding Tag}"
                          Fill="{TemplateBinding Foreground}"
                          Margin="{TemplateBinding Padding}"/>
                </Grid>
            </Viewbox>
        </ControlTemplate>


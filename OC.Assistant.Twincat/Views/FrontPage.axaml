<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OC.Assistant.Twincat.ViewModels"
             xmlns:views="clr-namespace:OC.Assistant.Twincat.Views"
             x:Class="OC.Assistant.Twincat.Views.FrontPage"
             x:DataType="vm:FrontPageViewModel"
             HorizontalAlignment="Left"
             Margin="10,0 0 0">
    <UserControl.DataContext>
        <vm:FrontPageViewModel/>
    </UserControl.DataContext>
    <StackPanel Orientation="Horizontal">
        <Button Classes="Secondary" Margin="4,0" Command="{Binding OpenCommand}" Content="open"/>
        <Label HorizontalAlignment="Center" VerticalAlignment="Center"
               Foreground="{DynamicResource SystemBaseMediumLowColor}" Content=","/>
        <Button Classes="Secondary" Margin="4,0" Command="{Binding CreateCommand}" Content="create"/>
        <Label HorizontalAlignment="Center" VerticalAlignment="Center"
               Foreground="{DynamicResource SystemBaseMediumLowColor}" Content="or"/>
        <views:DteSelector Margin="4,0"/>
        <Label HorizontalAlignment="Center" VerticalAlignment="Center"
               Foreground="{DynamicResource SystemBaseMediumLowColor}" Content="a TwinCAT solution"/>
    </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OC.Assistant.Twincat.ViewModels"
             x:Class="OC.Assistant.Twincat.Views.Settings"
             x:DataType="vm:SettingsViewModel"
             Margin="5,20">
    <StackPanel>
        <Label Margin="4,0,0,0" Content="PlcName"/>
        <ComboBox ItemsSource="{Binding PlcProjects}"
                  SelectedItem="{Binding SelectedPlcProject, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  Margin="0,5,0,10"/>
        <Label Margin="4,0,0,0" Content="PlcTaskName"/>
        <ComboBox ItemsSource="{Binding PlcTasks}"
                  SelectedItem="{Binding SelectedPlcTask, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  Margin="0,5,0,10"/>
    </StackPanel>
</UserControl>

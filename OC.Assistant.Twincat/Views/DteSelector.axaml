<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OC.Assistant.Twincat.ViewModels"
             x:Class="OC.Assistant.Twincat.Views.DteSelector"
             x:DataType="vm:DteSelectorViewModel">
    <UserControl.DataContext>
        <vm:DteSelectorViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Menu Margin="-2,28,0,0">
            <MenuItem
                Height="0"
                ItemsSource="{Binding Items}"
                IsSubMenuOpen="{Binding IsSubmenuOpen, Mode=TwoWay}">
                <MenuItem.Styles>
                    <Style Selector="MenuItem MenuItem" x:DataType="vm:SolutionItem">
                        <Setter Property="Header" Value="{Binding Name}"/>
                        <Setter Property="Command" Value="{Binding Command}"/>
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                    </Style>
                </MenuItem.Styles>
            </MenuItem>
        </Menu>
        <Button
            Classes="Secondary"
            Command="{Binding OpenSubmenuCommand}"
            Content="connect"/>
    </Grid>
</UserControl>
